<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:DailyOrganzier.Models"
               xmlns:enums="clr-namespace:DailyOrganzier.Models.Enums"
               x:Class="DailyOrganzier.Views.AddQuestPopup"
               x:TypeArguments="models:Quest"
               CanBeDismissedByTappingOutsideOfPopup="True"
               BackgroundColor="#1E1E1E">

    <Border Padding="20" BackgroundColor="#1E1E1E" StrokeShape="RoundRectangle 10" StrokeThickness="0" WidthRequest="320">
        <VerticalStackLayout Spacing="15">
            <Label Text="Add New Quest" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="White"/>

            <Entry x:Name="TitleEntry" Placeholder="Quest Title" Text="{Binding Title}" TextColor="White" PlaceholderColor="Gray"/>

            <Entry x:Name="XpEntry" Placeholder="XP Reward (max 15)" Keyboard="Numeric" Text="{Binding XpEntry}" TextColor="White" PlaceholderColor="Gray"/>
            
            <Picker x:Name="CategoryPicker" Title="Select Category" 
                    TitleColor="Gray" TextColor="White" 
                    SelectedItem="{Binding SelectedCategory}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type enums:QuestCategory}">
                        <enums:QuestCategory>CHORE</enums:QuestCategory>
                        <enums:QuestCategory>FITNESS</enums:QuestCategory>
                        <enums:QuestCategory>WORK</enums:QuestCategory>
                        <enums:QuestCategory>LEARNING</enums:QuestCategory>
                        <enums:QuestCategory>MINDFULNESS</enums:QuestCategory>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Label x:Name="ErrorType" Text="{Binding ErrorType}" 
                   TextColor ="Red"
                   IsVisible="{Binding IsErrorVisible}"
                   HorizontalTextAlignment="Center"/>

            <HorizontalStackLayout Spacing="15" HorizontalOptions="End" Margin="0,10,0,0">
                <Button Text="Cancel" BackgroundColor="Transparent" TextColor="Gray" Clicked="OnCancelClicked"/>
                <Button Text="Save Quest" BackgroundColor="#4CAF50" TextColor="White" Command="{Binding SaveNewQuestCommand}"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>